{
  "_comment": "Using pre-built DLLs instead of .csproj due to DocFX lacking C# 14 support. See https://github.com/dotnet/docfx/issues/10808",
  "metadata": [
    {
      "src": [
        {
          "files": [
            "src/NOF.Abstraction/bin/Release/net10.0/NOF.Abstraction.dll",
            "src/NOF.Domain/bin/Release/net10.0/NOF.Domain.dll",
            "src/NOF.Contract/bin/Release/net10.0/NOF.Contract.dll",
            "src/NOF.Application/bin/Release/net10.0/NOF.Application.dll",
            "src/NOF.Hosting.Abstraction/bin/Release/net10.0/NOF.Hosting.Abstraction.dll",
            "src/NOF.Infrastructure/bin/Release/net10.0/NOF.Infrastructure.dll",
            "src/NOF.UI/bin/Release/net10.0/NOF.UI.dll",
            "src/NOF.Test/bin/Release/net10.0/NOF.Test.dll",
            "src/Hostings/NOF.Hosting.AspNetCore/bin/Release/net10.0/NOF.Hosting.AspNetCore.dll",
            "src/Hostings/NOF.Hosting.BlazorWebAssembly/bin/Release/net10.0/NOF.Hosting.BlazorWebAssembly.dll",
            "src/Hostings/NOF.Hosting.Console/bin/Release/net10.0/NOF.Hosting.Console.dll",
            "src/Hostings/NOF.Hosting.Maui/bin/Release/net10.0/NOF.Hosting.Maui.dll",
            "src/Extensions/NOF.Contract.Extension.Authorization.Jwt/bin/Release/net10.0/NOF.Contract.Extension.Authorization.Jwt.dll",
            "src/Extensions/NOF.Hosting.Extension.Authorization.Jwt/bin/Release/net10.0/NOF.Hosting.Extension.Authorization.Jwt.dll",
            "src/Extensions/NOF.Infrastructure.Extension.Authorization.Jwt/bin/Release/net10.0/NOF.Infrastructure.Extension.Authorization.Jwt.dll",
            "src/Infrastructures/NOF.Infrastructure.RabbitMQ/bin/Release/net10.0/NOF.Infrastructure.RabbitMQ.dll",
            "src/Infrastructures/NOF.Infrastructure.StackExchangeRedis/bin/Release/net10.0/NOF.Infrastructure.StackExchangeRedis.dll"
          ]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api/**.yml",
          "api/index.md"
        ]
      },
      {
        "files": [
          "**.md",
          "**.yml"
        ],
        "exclude": [
          "api/**"
        ],
        "src": "docs/"
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ],
        "src": "docs/"
      }
    ],
    "output": "_site",
    "globalMetadataFiles": [],
    "fileMetadataFiles": [],
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appTitle": "NOF Framework",
      "_appFooter": "NOF Framework Documentation",
      "_enableSearch": true
    }
  }
}
