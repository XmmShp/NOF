@using NOF.Contract
@if (_requiredPermission is null)
{
    <RouteView RouteData="@RouteData" DefaultLayout="@DefaultLayout" />
}
else
{
    <AuthGuard Permission="@_requiredPermission" AuthorizingContent="@AuthorizingContent"
               UnauthorizedContent="@UnauthorizedContent">
        <RouteView RouteData="@RouteData" DefaultLayout="@DefaultLayout" />
    </AuthGuard>
}

@code {
    [Parameter, EditorRequired] public RouteData RouteData { get; set; } = default!;
    [Parameter] public Type? DefaultLayout { get; set; }
    [Parameter] public RenderFragment? AuthorizingContent { get; set; }
    [Parameter] public RenderFragment? UnauthorizedContent { get; set; }

    private string? _requiredPermission;

    protected override void OnParametersSet()
    {
        _requiredPermission = PermissionRouteViewMetadataResolver.ResolveRequiredPermission(RouteData.PageType);
    }
}
