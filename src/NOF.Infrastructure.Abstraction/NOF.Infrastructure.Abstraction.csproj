<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <!-- AOT Compatibility -->
    <IsAotCompatible>true</IsAotCompatible>
    <VerifyReferenceAotCompatibility>true</VerifyReferenceAotCompatibility>

    <!-- NuGet Package Settings -->
    <PackageId>NOF.Infrastructure.Abstraction</PackageId>
    <Description>Abstractions for the NOF Framework infrastructure — interfaces, pipeline contracts, context types, and options shared across infrastructure implementations.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Options.DataAnnotations" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\NOF.Application\NOF.Application.csproj" />
  </ItemGroup>

</Project>
