<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <!-- AOT Compatibility -->
    <IsAotCompatible>true</IsAotCompatible>

	  <IsPackable>true</IsPackable>
	  <PackageId>NOF.Hosting.AspNetCore</PackageId>
	  <Description>ASP.NET Core hosting for the NOF Framework - OpenAPI service registration, JSON configuration, and CORS.</Description>
  </PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.AspNetCore.OpenApi" />
		<PackageReference Include="OpenTelemetry.Instrumentation.AspNetCore" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\..\NOF.Infrastructure\NOF.Infrastructure.csproj" />
	</ItemGroup>

</Project>
