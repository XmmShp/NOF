<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsAotCompatible>true</IsAotCompatible>
    <EnableConfigurationBindingGenerator>true</EnableConfigurationBindingGenerator>

    <IsPackable>true</IsPackable>
    <PackageId>NOF.Hosting.BlazorWebAssembly</PackageId>
    <Description>Blazor WebAssembly hosting for the NOF Framework — adapts WebAssemblyHostBuilder to the NOF application builder pipeline.</Description>
  </PropertyGroup>

  <ItemGroup>
    <SupportedPlatform Include="browser" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\NOF.Infrastructure\NOF.Infrastructure.csproj" />
    <ProjectReference Include="..\..\NOF.UI\NOF.UI.csproj" />
  </ItemGroup>

</Project>
