<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>

    <!-- AOT Compatibility -->
    <IsAotCompatible>true</IsAotCompatible>
    <EnableConfigurationBindingGenerator>true</EnableConfigurationBindingGenerator>

    <IsPackable>true</IsPackable>
    <PackageId>NOF.Hosting.Console</PackageId>
    <Description>Console hosting for the NOF Framework — integrates the NOF step pipeline with Microsoft.Extensions.Hosting.</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\NOF.Hosting.Abstraction\NOF.Hosting.Abstraction.csproj" />
    <ProjectReference Include="..\..\NOF.Infrastructure\NOF.Infrastructure.csproj" />
  </ItemGroup>

</Project>
