<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:NOF.Sample.Maui"
             xmlns:ui="clr-namespace:NOF.Sample.UI.Components;assembly=NOF.Sample.UI"
             x:Class="NOF.Sample.Maui.MainPage">

    <BlazorWebView x:Name="blazorWebView" HostPage="wwwroot/index.html">
        <BlazorWebView.RootComponents>
            <RootComponent Selector="#app" ComponentType="{x:Type ui:Routes}" />
        </BlazorWebView.RootComponents>
    </BlazorWebView>

</ContentPage>
