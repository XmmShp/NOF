@page "/oidc-demo"
@using System.Security.Cryptography
@using System.Text
@inject NavigationManager NavigationManager

<PageTitle>OIDC Demo</PageTitle>

<style>
    .demo-section {
        margin-bottom: 24px;
    }

    .mono-block {
        background: #f5f5f5;
        border-radius: 6px;
        font-family: Consolas, monospace;
        font-size: 12px;
        padding: 12px;
        white-space: pre-wrap;
        word-break: break-all;
    }
</style>

<h3>OIDC Demo</h3>

<Alert Type="AlertType.Info" ShowIcon="true"
       Message="Sample server now exposes standard OAuth 2.1 / OpenID Connect endpoints."
       Description="The sample authorization handler auto-approves a fixed demo subject named demo-user so you can verify discovery, authorization-code + PKCE, token, userinfo, and JWKS end-to-end." />

<Row Gutter="16" style="margin-top: 16px;">
    <Col Span="12">
    <Card Title="Discovery Endpoints" Class="demo-section">
        <Descriptions Column="1" Size="@DescriptionsSize.Small" Bordered>
            <DescriptionsItem Title="Issuer">@Issuer</DescriptionsItem>
            <DescriptionsItem Title="OpenID Configuration"><a href="@OpenIdConfigurationUrl"
                                                                  target="_blank">@OpenIdConfigurationUrl</a></DescriptionsItem>
                <DescriptionsItem Title="Authorization Server Metadata"><a href="@AuthorizationMetadataUrl"
                                                                               target="_blank">@AuthorizationMetadataUrl</a></DescriptionsItem>
                    <DescriptionsItem Title="JWKS"><a href="@JwksUrl" target="_blank">@JwksUrl</a></DescriptionsItem>
                    <DescriptionsItem Title="Authorize">@AuthorizeEndpoint</DescriptionsItem>
                    <DescriptionsItem Title="Token">@TokenEndpoint</DescriptionsItem>
                    <DescriptionsItem Title="UserInfo">@UserInfoEndpoint</DescriptionsItem>
                </Descriptions>
            </Card>
        </Col>
        <Col Span="12">
        <Card Title="Authorize URL Builder" Class="demo-section">
            <Form Layout="@FormLayout.Vertical" TModel="OidcDemoModel">
                <FormItem Label="Client ID">
                    <Input @bind-Value="_model.ClientId" />
                </FormItem>
                <FormItem Label="Redirect URI">
                    <Input @bind-Value="_model.RedirectUri" />
                </FormItem>
                <FormItem Label="Scope">
                    <Input @bind-Value="_model.Scope" />
                </FormItem>
                <FormItem Label="State">
                    <Input @bind-Value="_model.State" />
                </FormItem>
                <FormItem Label="Nonce">
                    <Input @bind-Value="_model.Nonce" />
                </FormItem>
                <FormItem>
                    <Button Type="@ButtonType.Default" OnClick="@GeneratePkce">Generate PKCE</Button>
                    <Button Type="@ButtonType.Primary" Style="margin-left: 8px;" OnClick="@BuildAuthorizeUrl">Build
                        URL</Button>
                    </FormItem>
                </Form>
            </Card>
        </Col>
    </Row>

    <Row Gutter="16">
        <Col Span="12">
        <Card Title="PKCE" Class="demo-section">
            <Descriptions Column="1" Size="@DescriptionsSize.Small" Bordered>
                <DescriptionsItem Title="Code Verifier">
                    <div class="mono-block">@_model.CodeVerifier</div>
                </DescriptionsItem>
                <DescriptionsItem Title="Code Challenge">
                    <div class="mono-block">@_model.CodeChallenge</div>
                </DescriptionsItem>
                <DescriptionsItem Title="Method">S256</DescriptionsItem>
            </Descriptions>
        </Card>
    </Col>
    <Col Span="12">
    <Card Title="Authorization Request" Class="demo-section">
        <div class="mono-block">@_authorizeUrl</div>
    </Card>
</Col>
</Row>

<Card Title="Try It" Class="demo-section">
    <Descriptions Column="1" Size="@DescriptionsSize.Small" Bordered>
        <DescriptionsItem Title="Step 1">Open the generated authorize URL in a new browser tab.</DescriptionsItem>
        <DescriptionsItem Title="Step 2">The sample server redirects back with a standard authorization code.
        </DescriptionsItem>
        <DescriptionsItem Title="Step 3">Exchange that code at the token endpoint with the code verifier shown above.
        </DescriptionsItem>
        <DescriptionsItem Title="Step 4">Call the userinfo endpoint with the returned bearer token.</DescriptionsItem>
    </Descriptions>
    <div class="mono-block" style="margin-top: 12px;">curl -X POST @TokenEndpoint \
        -H \"Content-Type: application/x-www-form-urlencoded\" \
        -d
        \"grant_type=authorization_code&client_id=@_model.ClientId&code=YOUR_CODE&redirect_uri=@Uri.EscapeDataString(_model.RedirectUri)&code_verifier=@_model.CodeVerifier\"
    </div>
</Card>

@code {
    private readonly OidcDemoModel _model = new();
    private string _authorizeUrl = string.Empty;

    private string BaseUri => NavigationManager.BaseUri.TrimEnd('/');
    private string Issuer => $"{BaseUri}/oauth2";
    private string OpenIdConfigurationUrl => $"{Issuer}/.well-known/openid-configuration";
    private string AuthorizationMetadataUrl => $"{BaseUri}/.well-known/oauth-authorization-server/oauth2";
    private string JwksUrl => $"{Issuer}/.well-known/jwks.json";
    private string AuthorizeEndpoint => $"{Issuer}/authorize";
    private string TokenEndpoint => $"{Issuer}/token";
    private string UserInfoEndpoint => $"{Issuer}/userinfo";

    protected override void OnInitialized()
    {
        _model.RedirectUri = $"{BaseUri}/oidc-callback";
        GeneratePkce();
        BuildAuthorizeUrl();
    }

    private void GeneratePkce()
    {
        Span<byte> buffer = stackalloc byte[32];
        RandomNumberGenerator.Fill(buffer);

        _model.CodeVerifier = Base64UrlEncode(buffer.ToArray());
        _model.CodeChallenge = Base64UrlEncode(SHA256.HashData(Encoding.ASCII.GetBytes(_model.CodeVerifier)));
        BuildAuthorizeUrl();
    }

    private void BuildAuthorizeUrl()
    {
        _authorizeUrl =
            $"{AuthorizeEndpoint}?response_type=code" +
            $"&client_id={Uri.EscapeDataString(_model.ClientId)}" +
            $"&redirect_uri={Uri.EscapeDataString(_model.RedirectUri)}" +
            $"&scope={Uri.EscapeDataString(_model.Scope)}" +
            $"&state={Uri.EscapeDataString(_model.State)}" +
            $"&nonce={Uri.EscapeDataString(_model.Nonce)}" +
            $"&code_challenge={Uri.EscapeDataString(_model.CodeChallenge)}" +
            "&code_challenge_method=S256";
    }

    private static string Base64UrlEncode(byte[] value)
    {
        return Convert.ToBase64String(value)
            .TrimEnd('=')
            .Replace('+', '-')
            .Replace('/', '_');
    }

    private sealed class OidcDemoModel
    {
        public string ClientId { get; set; } = "nof-sample-ui";

        public string RedirectUri { get; set; } = string.Empty;

        public string Scope { get; set; } = "openid profile email";

        public string State { get; set; } = "sample-state";

        public string Nonce { get; set; } = "sample-nonce";

        public string CodeVerifier { get; set; } = string.Empty;

        public string CodeChallenge { get; set; } = string.Empty;
    }
}
